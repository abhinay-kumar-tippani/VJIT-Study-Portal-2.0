# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/vjit-portal?retryWrites=true&w=majority

# AES-256-CBC Encryption Key — must be exactly 32 characters
ENCRYPTION_KEY=your-32-character-secret-key-here

# JWT Secret — any long random string
JWT_SECRET=your-super-secret-jwt-signing-key-change-me

# Google Cloud Storage (for community uploads)
GCS_BUCKET_NAME=your-bucket-name
# Paste the full service account JSON as a single-line base64 string:
# cat service-account.json | base64 -w 0
GCS_SERVICE_ACCOUNT_KEY_JSON=base64-encoded-service-account-json

# Next.js public URL (for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
